{
  "github": {
    "silent": true
  },
  "buildCommand": "python run_pipeline.py --step export || echo 'Build script optional'",
  "cleanUrls": true,
  "trailingSlash": false,
  "public": false,
  "rewrites": [
    { "source": "/", "destination": "/web/index.html" },
    { "source": "/index.html", "destination": "/web/index.html" },
    { "source": "/style.css", "destination": "/web/style.css" },
    { "source": "/main.js", "destination": "/web/main.js" },
    { "source": "/data/(.*)", "destination": "/web/data/$1" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
